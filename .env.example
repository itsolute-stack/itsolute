# =============================================================================
# ITSolute Systems — environment variables
# Copy to .env.local for development. Set the same values in Vercel for prod.
# =============================================================================

# Resend — transactional email for contact form
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL="ITSolute Systems <hello@itsolute.com>"
RESEND_TO_EMAIL=hello@itsolute.com

# Public contact (used in WhatsApp links, tel: links)
NEXT_PUBLIC_WHATSAPP_NUMBER=919207640404
NEXT_PUBLIC_PHONE_NUMBER=+919207640404

# Analytics (optional — leave blank to skip)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Canonical site URL — used in metadata, sitemap, schema.
# Override to the Vercel URL (e.g. https://itsolute-i68y.vercel.app) while
# itsolute.com is not yet live so search engines don't see a broken canonical.
NEXT_PUBLIC_SITE_URL=https://itsolute.com
